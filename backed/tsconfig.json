{
  "ts-node": {
    "transpileOnly": true
  },
  "extends": "@eggjs/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "strict": false,
    "paths": {
      "@/module/*": ["app/module/*"]
    },
    "baseUrl": "."
  }
}
